# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ke_ecommerce

# Redis
REDIS_URL=redis://localhost:6379

# Medusa
JWT_SECRET=your-jwt-secret-change-this
COOKIE_SECRET=your-cookie-secret-change-this
MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000,http://localhost:3000

# Storage (Cloudflare R2)
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=

# Email
RESEND_API_KEY=
SENDER_EMAIL=orders@yourdomain.com
STORE_URL=http://localhost:3000

# SMS (Africa's Talking)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# Payments — M-Pesa (Safaricom Daraja)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENV=sandbox

# M-Pesa STK Push callback (must be a public HTTPS URL — use ngrok for local dev)
MPESA_CALLBACK_URL=https://your-ngrok-id.ngrok.io/hooks/mpesa/stk

# M-Pesa C2B (Till/Paybill) — set these when using the Manual Till flow
# Both must be public HTTPS URLs registered with Safaricom Daraja C2B API
MPESA_C2B_CONFIRMATION_URL=https://your-ngrok-id.ngrok.io/hooks/mpesa/c2b/confirmation
MPESA_C2B_VALIDATION_URL=https://your-ngrok-id.ngrok.io/hooks/mpesa/c2b/validation

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# MeiliSearch (leave blank to disable product search — Medusa default search is used instead)
MEILISEARCH_HOST=
MEILISEARCH_KEY=
